{
  "permission": {
    "*": "ask",
    "path": {
      "./*": "allow",
      "./.*": "allow",
      "~/.ssh/*": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "rm -rf *": "deny",
      "sudo *": "ask"
    },
    "external_directory": {
      "*": "deny",
      "~/Documents/sjb-brain/*": "allow"
    }
  },
  "debugLog": false,
  "permissionReviewLog": true,
  "yoloMode": true
}
